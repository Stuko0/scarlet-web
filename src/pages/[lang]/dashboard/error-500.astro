import DashboardLayout from "../../../components/dashboard/base/DashboardLayout.astro"
import GraphicElementView from "../../../components/dashboard/views/GraphicElementView.astro"
---
<DashboardLayout title="500 Error de Servidor">
    <h1 class="text-2xl font-bold font-titles text-gray-800 mb-1">Página 500</h1>
