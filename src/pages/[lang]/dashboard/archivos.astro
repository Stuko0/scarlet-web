---
export function getStaticPaths() { return ['es','en','fr','pt','br'].map(lang => ({ params: { lang } })); }
import DashboardLayout from "../../../components/dashboard/base/DashboardLayout.astro"
import FileManagerView from "../../../components/dashboard/views/FileManagerView.astro"
---
<DashboardLayout title="Gestor de Archivos">
    <h1 class="text-2xl font-bold font-titles text-gray-800 mb-1">Gestor de Archivos</h1>
    <p class="text-sm text-gray-500 mb-6">Gestiona, comparte y organiza archivos multimedia.</p>
    <FileManagerView viewTitle="Gestor de Archivos" />
</DashboardLayout>
