---
export function getStaticPaths() {
  const langs = ['es', 'en', 'fr', 'pt', 'br'];
  const views = [
    'panel-entidades',
    'panel-admin',
    'panel-orquestador',
    'panel-entidad',
    'panel-estacion',
    'panel-equipo',
    'mantenimiento',
    'error-404',
    'error-500',
    'formularios',
    'archivos',
    'olvido-contrasena',
    'restablecer-contrasena',
    'equipos',
    'entidades',
    'tareas',
    'usuarios',
    'settings'
  ];
  return langs.flatMap(lang => views.map(view => ({ params: { lang, view } })));
}

import Layout from "../../../layouts/Layout.astro"
import Sidebar from "../../../components/dashboard/base/Sidebar.astro"
import { getLangFromUrl, useTranslations } from "../../../i18n/utils";

import GraphicElementView from "../../../components/dashboard/views/GraphicElementView.astro"
import FileManagerView from "../../../components/dashboard/views/FileManagerView.astro"
import FormManagerView from "../../../components/dashboard/views/FormManagerView.astro"
import WebFunctionView from "../../../components/dashboard/views/WebFunctionView.astro"
import PanelView from "../../../components/dashboard/views/PanelView.astro"
import SettingsView from "../../../components/dashboard/views/SettingsView.astro"
import Modal from "../../../components/dashboard/modals/Modal.astro"

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const { view } = Astro.params;

const titleMap = {
    'panel-entidades': 'Panel de Entidades',
    'panel-admin': 'Panel de Administrador',
    'panel-orquestador': 'Entidad Orquestadora',
    'panel-entidad': 'Panel de Entidad',
    'panel-estacion': 'Panel de Estación',
    'panel-equipo': 'Panel de Equipo',
    'mantenimiento': 'Mantenimiento',
    'error-404': '404 no encontrado',
    'error-500': '500 error de servidor',
    'formularios': 'Formularios',
    'archivos': 'Gestor de Archivos',
    'olvido-contrasena': 'Olvido de contraseña',
    'restablecer-contrasena': 'Restablecer contraseña',
    'equipos': 'Equipos',
    'entidades': 'Entidades',
    'tareas': 'Tareas',
    'usuarios': 'Usuarios y Accesos',
    'settings': 'Ajustes'
};

const viewTitle = titleMap[view] || view;

const categoryMap = {
    'panel-entidades': 'Paneles',
    'panel-admin': 'Paneles',
    'panel-orquestador': 'Paneles',
    'panel-entidad': 'Paneles',
    'panel-estacion': 'Paneles',
    'panel-equipo': 'Paneles',
    'mantenimiento': 'Elementos Gráficos',
    'error-404': 'Elementos Gráficos',
    'error-500': 'Elementos Gráficos',
    'formularios': 'Elementos Gráficos',
    'archivos': 'Elementos Gráficos',
    'olvido-contrasena': 'Funciones Web',
    'restablecer-contrasena': 'Funciones Web',
    'equipos': 'Funciones Web',
    'entidades': 'Funciones Web',
    'tareas': 'Funciones Web',
    'usuarios': 'Funciones Web',
    'settings': 'Configuración'
};
const category = categoryMap[view] || 'Panel';
const breadcrumbs = [
    { label: 'Panel', href: `/${lang}/dashboard/Dashboard` },
    { label: category, href: '#' },
    { label: viewTitle }
];

const isWebFunction = ['equipos', 'entidades', 'tareas', 'olvido-contrasena', 'restablecer-contrasena', 'usuarios'].includes(view);
const isGraphicElement = ['mantenimiento', 'error-404', 'error-500'].includes(view);
const isFormManager = ['formularios'].includes(view);
const isFileManager = ['archivos'].includes(view);
const isPanel = ['panel-entidades'].includes(view) || view.startsWith('panel-');
const isSettings = ['settings'].includes(view);

const descMap = {
    file: 'Gestiona, comparte y organiza archivos multimedia.',
    form: 'Diseña cuestionarios y recopila respuestas en vivo.',
    default: `Gestión y configuración de la interfaz para ${viewTitle.toLowerCase()}`
};
const description = isFileManager ? descMap.file : isFormManager ? descMap.form : descMap.default;
---

<Layout title={`!Scarlet Dashboard - ${viewTitle}`}>
     <Sidebar />
     <main class="min-h-screen bg-[#f8f9fa] md:ml-[16rem]">
        <div class="p-4 md:p-8 pt-6 flex flex-col flex-1 min-h-[calc(100vh-70px)]">
            
            <div class="mb-8 flex flex-col sm:flex-row sm:justify-between sm:items-center gap-4">
                <div>
                   <h1 class="text-2xl font-bold font-titles text-gray-800">{viewTitle}</h1>
                   <p class="text-sm text-gray-500 mt-1">{description}</p>
                </div>
                {isWebFunction && (
                   <button data-modal-open="modal-new-record" class="bg-[#ea580c] hover:bg-[#c24106] text-white px-5 py-2.5 rounded-md font-medium text-sm transition-colors shadow-sm flex items-center justify-center min-w-max">
                      + Nuevo Registro
                   </button>
                )}
                {isGraphicElement && (
                   <div class="flex gap-3">
                       <button id="btn-preview" class="bg-white border text-gray-700 hover:bg-gray-50 px-5 py-2.5 rounded-md font-medium text-sm transition-colors shadow-sm flex items-center justify-center min-w-max">
                          <svg class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path></svg>
                          Vista Previa
                       </button>
                       <button class="bg-[#ea580c] hover:bg-[#c24106] text-white px-5 py-2.5 rounded-md font-medium text-sm transition-colors shadow-sm flex items-center justify-center min-w-max">
                          <svg class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-3m-1 4l-3 3m0 0l-3-3m3 3V4"></path></svg>
                          Guardar Diseño
                       </button>
                   </div>
                )}
                {isFormManager && (
                   <button data-modal-open="modal-new-form" class="bg-[#ea580c] hover:bg-[#c24106] text-white px-5 py-2.5 rounded-md font-medium text-sm transition-colors shadow-sm flex items-center justify-center min-w-max">
                      + Crear Formulario
                   </button>
                )}
                {isFileManager && (
                   <div class="flex gap-3">
                       <button data-modal-open="modal-new-folder" class="bg-white border text-gray-700 hover:bg-gray-50 px-5 py-2.5 rounded-md font-medium text-sm transition-colors shadow-sm flex items-center justify-center min-w-max">
                          <svg class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 13h6m-3-3v6m-9 1V7a2 2 0 012-2h6l2 2h6a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2z"></path></svg>
                          Nueva Carpeta
                       </button>
                       <button data-modal-open="modal-upload-files" class="bg-[#ea580c] hover:bg-[#c24106] text-white px-5 py-2.5 rounded-md font-medium text-sm transition-colors shadow-sm flex items-center justify-center min-w-max">
                          <svg class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-8l-4-4m0 0L8 8m4-4v12"></path></svg>
                          Subir Archivos
                       </button>
                   </div>
                )}
            </div>

            {isGraphicElement && <GraphicElementView viewTitle={viewTitle} />}
            {isFileManager && <FileManagerView viewTitle={viewTitle} />}
            {isFormManager && <FormManagerView viewTitle={viewTitle} />}
            {isWebFunction && <WebFunctionView viewTitle={viewTitle} />}
            {isPanel && <PanelView viewTitle={viewTitle} />}
            {isSettings && <SettingsView viewTitle={viewTitle} />}
            
        </div>
     </main>

     <!-- MODALS -->
     <Modal modalId="modal-new-record" title="Nuevo Registro">
         <form class="space-y-4" id="form-new-record">
             <div>
                 <label class="block text-sm font-semibold text-gray-700 mb-1">Nombre / Identificador</label>
                 <input type="text" id="nr-name" class="block w-full rounded-md border-gray-300 shadow-sm focus:border-[#ea580c] focus:ring focus:ring-[#ea580c]/20 sm:text-sm p-2.5 border" placeholder="Nombre del registro..." required />
             </div>
             <div>
                 <label class="block text-sm font-semibold text-gray-700 mb-1">Estado</label>
                 <select id="nr-status" class="block w-full rounded-md border-gray-300 shadow-sm focus:border-[#ea580c] focus:ring focus:ring-[#ea580c]/20 sm:text-sm p-2.5 border bg-white">
                     <option>Activo</option><option>En Revisión</option><option>Borrador</option>
                 </select>
             </div>
             <div>
                 <label class="block text-sm font-semibold text-gray-700 mb-1">Descripción</label>
                 <textarea id="nr-desc" rows="3" class="block w-full rounded-md border-gray-300 shadow-sm focus:border-[#ea580c] focus:ring focus:ring-[#ea580c]/20 sm:text-sm p-2.5 border" placeholder="Descripción breve..."></textarea>
             </div>
             <div class="flex justify-end gap-3 pt-4 border-t border-gray-100">
                 <button type="button" class="modal-close-btn px-5 py-2 border border-gray-300 rounded-md text-sm font-medium text-gray-700 hover:bg-gray-50" data-modal="modal-new-record">Cancelar</button>
                 <button type="button" id="nr-submit" class="px-5 py-2 bg-[#ea580c] hover:bg-[#c24106] text-white rounded-md text-sm font-semibold">Crear Registro</button>
             </div>
         </form>
     </Modal>

     <Modal modalId="modal-new-form" title="Crear Formulario">
         <form class="space-y-4" id="form-new-form">
             <div>
                 <label class="block text-sm font-semibold text-gray-700 mb-1">Nombre del Formulario</label>
                 <input type="text" id="nf-name" class="block w-full rounded-md border-gray-300 shadow-sm focus:border-[#ea580c] focus:ring focus:ring-[#ea580c]/20 sm:text-sm p-2.5 border" placeholder="Ej: Encuesta de satisfacción..." required />
             </div>
             <div>
                 <label class="block text-sm font-semibold text-gray-700 mb-1">URL Slug</label>
                 <div class="flex items-center">
                     <span class="text-sm text-gray-400 mr-1">scarlet.com/form/</span>
                     <input type="text" id="nf-url" class="flex-1 rounded-md border-gray-300 shadow-sm focus:border-[#ea580c] focus:ring focus:ring-[#ea580c]/20 sm:text-sm p-2.5 border font-mono" placeholder="mi-formulario" />
                 </div>
             </div>
             <div class="flex justify-end gap-3 pt-4 border-t border-gray-100">
                 <button type="button" class="modal-close-btn px-5 py-2 border border-gray-300 rounded-md text-sm font-medium text-gray-700 hover:bg-gray-50" data-modal="modal-new-form">Cancelar</button>
                 <button type="button" id="nf-submit" class="px-5 py-2 bg-[#ea580c] hover:bg-[#c24106] text-white rounded-md text-sm font-semibold">Crear Formulario</button>
             </div>
         </form>
     </Modal>

     <Modal modalId="modal-new-folder" title="Nueva Carpeta" size="sm">
         <form class="space-y-4">
             <div>
                 <label class="block text-sm font-semibold text-gray-700 mb-1">Nombre de la Carpeta</label>
                 <input type="text" id="nfol-name" class="block w-full rounded-md border-gray-300 shadow-sm focus:border-[#ea580c] focus:ring focus:ring-[#ea580c]/20 sm:text-sm p-2.5 border" placeholder="Nueva carpeta..." required />
             </div>
             <div class="flex justify-end gap-3 pt-4 border-t border-gray-100">
                 <button type="button" class="modal-close-btn px-5 py-2 border border-gray-300 rounded-md text-sm font-medium text-gray-700 hover:bg-gray-50" data-modal="modal-new-folder">Cancelar</button>
                 <button type="button" id="nfol-submit" class="px-5 py-2 bg-[#ea580c] hover:bg-[#c24106] text-white rounded-md text-sm font-semibold">Crear Carpeta</button>
             </div>
         </form>
     </Modal>

     <Modal modalId="modal-upload-files" title="Subir Archivos" size="lg">
         <div class="space-y-4">
             <div id="upload-drop-zone" class="border-2 border-dashed border-gray-300 rounded-xl p-10 text-center hover:border-[#ea580c] transition-colors cursor-pointer">
                 <svg class="mx-auto h-14 w-14 text-gray-300 mb-3" stroke="currentColor" fill="none" viewBox="0 0 48 48"><path d="M28 8H12a4 4 0 00-4 4v20m32-12v8m0 0v8a4 4 0 01-4 4H12a4 4 0 01-4-4v-4m32-4l-3.172-3.172a4 4 0 00-5.656 0L28 28M8 32l9.172-9.172a4 4 0 015.656 0L28 28m0 0l4 4m4-24h8m-4-4v8m-12 4h.02" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" /></svg>
                 <p class="text-sm text-gray-600 font-medium">Arrastra archivos aquí o <span class="text-[#ea580c] font-semibold">haz clic para explorar</span></p>
                 <p class="text-xs text-gray-400 mt-1">PNG, JPG, PDF, DOCX (max. 50MB)</p>
                 <input type="file" id="upload-input" class="hidden" multiple />
             </div>
             <div id="upload-file-list" class="space-y-2 max-h-40 overflow-y-auto"></div>
             <div class="flex justify-end gap-3 pt-4 border-t border-gray-100">
                 <button type="button" class="modal-close-btn px-5 py-2 border border-gray-300 rounded-md text-sm font-medium text-gray-700 hover:bg-gray-50" data-modal="modal-upload-files">Cancelar</button>
                 <button type="button" id="upload-submit" class="px-5 py-2 bg-[#ea580c] hover:bg-[#c24106] text-white rounded-md text-sm font-semibold">Subir</button>
             </div>
         </div>
     </Modal>

     <!-- Toast notification -->
     <div id="toast" class="fixed bottom-6 right-6 z-[10000] hidden">
         <div class="bg-gray-900 text-white px-5 py-3 rounded-lg shadow-xl text-sm font-medium flex items-center gap-2">
             <svg class="w-5 h-5 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
             <span id="toast-msg">Acción completada</span>
         </div>
     </div>
</Layout>

<script is:inline>
(function(){
    function showToast(msg){
        const t=document.getElementById('toast'),m=document.getElementById('toast-msg');
        if(t&&m){m.textContent=msg;t.classList.remove('hidden');setTimeout(()=>t.classList.add('hidden'),3000);}
    }

    // New Record modal submit
    document.getElementById('nr-submit')?.addEventListener('click',()=>{
        const n=document.getElementById('nr-name'),s=document.getElementById('nr-status');
        if(n&&n.value.trim()){
            if(window.addNewRecord)window.addNewRecord(n.value,s?s.value:'Activo','');
            n.value='';window.closeModal('modal-new-record');showToast('Registro creado exitosamente');
        }
    });

    // New Form modal submit
    document.getElementById('nf-submit')?.addEventListener('click',()=>{
        const n=document.getElementById('nf-name'),u=document.getElementById('nf-url');
        if(n&&n.value.trim()){
            if(window.addNewForm)window.addNewForm(n.value,u?u.value:'new-form');
            n.value='';if(u)u.value='';window.closeModal('modal-new-form');showToast('Formulario creado exitosamente');
        }
    });

    // New Folder modal submit
    document.getElementById('nfol-submit')?.addEventListener('click',()=>{
        const n=document.getElementById('nfol-name');
        if(n&&n.value.trim()){n.value='';window.closeModal('modal-new-folder');showToast('Carpeta creada exitosamente');}
    });

    // Upload files modal
    const dz=document.getElementById('upload-drop-zone'),fi=document.getElementById('upload-input'),fl=document.getElementById('upload-file-list');
    let selectedFiles=[];
    dz?.addEventListener('click',()=>fi?.click());
    dz?.addEventListener('dragover',(e)=>{e.preventDefault();dz.classList.add('border-[#ea580c]','bg-orange-50');});
    dz?.addEventListener('dragleave',()=>{dz.classList.remove('border-[#ea580c]','bg-orange-50');});
    dz?.addEventListener('drop',(e)=>{e.preventDefault();dz.classList.remove('border-[#ea580c]','bg-orange-50');addFiles(e.dataTransfer.files);});
    fi?.addEventListener('change',()=>{if(fi.files)addFiles(fi.files);});

    function addFiles(files){
        for(const f of files)selectedFiles.push(f);
        renderFileList();
    }
    function renderFileList(){
        if(!fl)return;
        fl.innerHTML=selectedFiles.map((f,i)=>`<div class="flex items-center justify-between bg-gray-50 p-3 rounded-lg border">
            <div class="flex items-center gap-2"><svg class="w-4 h-4 text-gray-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4z" clip-rule="evenodd"/></svg>
            <span class="text-sm text-gray-700 font-medium">${f.name}</span><span class="text-xs text-gray-400">${(f.size/1024).toFixed(1)} KB</span></div>
            <button class="text-red-400 hover:text-red-600 uf-rm" data-idx="${i}">✕</button></div>`).join('');
        fl.querySelectorAll('.uf-rm').forEach(b=>b.addEventListener('click',()=>{selectedFiles.splice(parseInt(b.dataset.idx),1);renderFileList();}));
    }
    document.getElementById('upload-submit')?.addEventListener('click',()=>{
        if(selectedFiles.length>0){selectedFiles=[];if(fl)fl.innerHTML='';window.closeModal('modal-upload-files');showToast(`Archivos subidos exitosamente`);}
    });

    // Preview button for graphic elements
    document.getElementById('btn-preview')?.addEventListener('click',()=>{if(window.openGraphicPreview)window.openGraphicPreview();});
})();
</script>
