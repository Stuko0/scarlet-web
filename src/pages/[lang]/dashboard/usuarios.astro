---
export function getStaticPaths() { return ['es','en','fr','pt','br'].map(lang => ({ params: { lang } })); }
import DashboardLayout from "../../../components/dashboard/base/DashboardLayout.astro"
import DataGridView from "../../../components/dashboard/datagrid/DataGridView.astro"
import SideDrawer from "../../../components/dashboard/datagrid/SideDrawer.astro"

const columns = [
    { key: 'name', label: 'Nombre' },
    { key: 'role', label: 'Rol' },
    { key: 'entity', label: 'Entidad' },
    { key: 'status', label: 'Estado' },
];
const filters = [
    { label: 'Rol', values: ['Admin', 'Operador', 'Bombero', 'Voluntario'] },
    { label: 'Estado', values: ['Activo', 'Inactivo'] },
];
const fields = [
    { key: 'name', label: 'Nombre Completo', type: 'text' },
    { key: 'email', label: 'Correo Electrónico', type: 'email' },
    { key: 'role', label: 'Rol', type: 'select', options: ['Admin', 'Gerente', 'Jefe de Estación', 'Jefe de Equipo', 'Operador', 'Bombero', 'Voluntario'] },
    { key: 'entity', label: 'Entidad Asignada', type: 'text' },
    { key: 'status', label: 'Estado', type: 'select', options: ['Activo', 'Inactivo', 'Suspendido'] },
];
---
<DashboardLayout title="Usuarios y Accesos">
    <h1 class="text-2xl font-bold font-titles text-gray-800 mb-1">Usuarios y Accesos</h1>
    <p class="text-sm text-gray-500 mb-6">Gestión de usuarios del sistema, roles y permisos de acceso.</p>
    <DataGridView viewTitle="Usuarios" columns={columns} filterOptions={filters} />
    <SideDrawer fields={fields} />
</DashboardLayout>
