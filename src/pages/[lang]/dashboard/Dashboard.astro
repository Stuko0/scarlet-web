---
export function getStaticPaths() {
  return [
    { params: { lang: 'es' } },
    { params: { lang: 'en' } },
    { params: { lang: 'fr' } },
    { params: { lang: 'pt' } },
    { params: { lang: 'br' } },
  ];
}

import DashboardLayout from "../../../components/dashboard/base/DashboardLayout.astro"
import TopBarKPIs from "../../../components/dashboard/tactical/TopBarKPIs.astro"
import TacticalMap from "../../../components/dashboard/tactical/TacticalMap.astro"
import ActionablesPanel from "../../../components/dashboard/tactical/ActionablesPanel.astro"
import TrendChart from "../../../components/dashboard/tactical/TrendChart.astro"
---
<DashboardLayout title="Centro de Mando Táctico" fullBleed>
    <div class="p-4 md:p-6 flex flex-col gap-4 min-h-screen">
        <TopBarKPIs />
        <div class="flex flex-col lg:flex-row gap-4 flex-1">
            <TacticalMap />
            <ActionablesPanel />
