---
export function getStaticPaths() { return ['es','en','fr','pt','br'].map(lang => ({ params: { lang } })); }
import DashboardLayout from "../../../components/dashboard/base/DashboardLayout.astro"
import FormManagerView from "../../../components/dashboard/views/FormManagerView.astro"
---
<DashboardLayout title="Formularios">
    <h1 class="text-2xl font-bold font-titles text-gray-800 mb-1">Formularios</h1>
    <p class="text-sm text-gray-500 mb-6">Diseña cuestionarios y recopila respuestas en vivo.</p>
    <FormManagerView viewTitle="Formularios" />
</DashboardLayout>
