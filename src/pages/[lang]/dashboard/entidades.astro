---
export function getStaticPaths() { return ['es','en','fr','pt','br'].map(lang => ({ params: { lang } })); }
import DashboardLayout from "../../../components/dashboard/base/DashboardLayout.astro"
import DataGridView from "../../../components/dashboard/datagrid/DataGridView.astro"
import SideDrawer from "../../../components/dashboard/datagrid/SideDrawer.astro"

const columns = [
    { key: 'name', label: 'Nombre de Entidad' },
    { key: 'region', label: 'Región' },
    { key: 'stations', label: 'Estaciones' },
    { key: 'status', label: 'Estado' },
];
const filters = [
    { label: 'Estado', values: ['Activo', 'Inactivo'] },
];
const fields = [
    { key: 'name', label: 'Nombre de la Entidad', type: 'text' },
    { key: 'region', label: 'Región / Ciudad', type: 'text' },
    { key: 'manager', label: 'Gerente de Entidad', type: 'text' },
    { key: 'stations', label: 'Número de Estaciones', type: 'number' },
    { key: 'status', label: 'Estado', type: 'select', options: ['Activo', 'Inactivo'] },
];
---
<DashboardLayout title="Gestión de Entidades">
    <h1 class="text-2xl font-bold font-titles text-gray-800 mb-1">Gestión de Entidades</h1>
    <p class="text-sm text-gray-500 mb-6">Administración de entidades, regiones y gerentes asociados.</p>
    <DataGridView viewTitle="Entidades" columns={columns} filterOptions={filters} />
    <SideDrawer fields={fields} />
</DashboardLayout>
