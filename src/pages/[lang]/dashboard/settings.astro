---
export function getStaticPaths() { return ['es','en','fr','pt','br'].map(lang => ({ params: { lang } })); }
import DashboardLayout from "../../../components/dashboard/base/DashboardLayout.astro"
import SettingsView from "../../../components/dashboard/views/SettingsView.astro"
---
<DashboardLayout title="Ajustes">
    <h1 class="text-2xl font-bold font-titles text-gray-800 mb-1">Ajustes</h1>
    <p class="text-sm text-gray-500 mb-6">Perfil, seguridad y preferencias del sistema.</p>
    <SettingsView viewTitle="Ajustes" />
</DashboardLayout>
