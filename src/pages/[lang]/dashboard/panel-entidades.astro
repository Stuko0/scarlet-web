---
export function getStaticPaths() { return ['es','en','fr','pt','br'].map(lang => ({ params: { lang } })); }
import DashboardLayout from "../../../components/dashboard/base/DashboardLayout.astro"
import PanelView from "../../../components/dashboard/views/PanelView.astro"
---
<DashboardLayout title="Panel de Entidades">
    <h1 class="text-2xl font-bold font-titles text-gray-800 mb-1">Panel de Entidades</h1>
    <p class="text-sm text-gray-500 mb-6">Vista general de todas las entidades registradas en el sistema.</p>
    <PanelView viewTitle="Panel de Entidades" />
</DashboardLayout>
