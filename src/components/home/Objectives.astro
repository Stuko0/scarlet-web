---
import { Image } from 'astro:assets';
import Monkey from "../../../public/images/monkey-tunari.jpg"
import Llamitas from "../../../public/images/llamitas-tunari.jpg"
import Cemento from "../../../public/images/cemento-con-bigote.png"
import PrimaryButton from '../buttons/PrimaryButton.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<article id="sobre-el-proyecto" class="md:mt-[-50px] px-5 md:px-0 mb-20 md:mb-32 md:mr-8 md:ml-8 mx-auto lg:ml-auto lg:mr-auto">
    <div class="md:max-w-6xl max-w-lg mx-auto">
        <div class="grid md:grid-cols-[60%_40%] gap-0">
            <div class="w-full relative">
                <div class="bg-[#1e2738] bg-cover bg-center w-full h-96 absolute overflow-hidden">
                    <picture class="flex bg-transparent" draggable="false">
                        <source srcset="https://www.estilodeviajes.com/wp-content/uploads/2021/03/parque-nacional-tunari-1024x1024.jpg" media="(max-width: 700px)" type="image/jpg">
                        <Image src={Llamitas} class="grayscale mix-blend-luminosity object-cover opacity-[0.2] w-full h-full md:h-[400px]" alt="llamitas" loading="lazy"/>
                    </picture>
                </div>
                <div class="pl-20 py-16 pr-20 text-left relative z-10">
                    <h1 class="inset-0 uppercase text-[#aacb6a] text-lg md:text-4xl leading-6 font-titles">{t('obj.impact.title')}</h1>
                    <p class="text-white my-5 text-sm md:text-base leading-6 font-body">{t('obj.impact.desc')}</p>
                    <PrimaryButton mx="0"><a href="https://www.globalforestwatch.org/dashboards/country/BOL/2">{t('obj.impact.btn')}</a></PrimaryButton>
                </div>
            </div>
            <div class="w-full relative ">
                <div class="bg-[#627d2c] bg-cover bg-center w-full h-96 absolute overflow-hidden">
                    <picture class="flex bg-transparent" draggable="false">
                        <source srcset="https://bolivianexpress3.s3-us-west-1.amazonaws.com/article_image/ulohzFPc2s.jpg" type="image/jpg">
                        <Image src={Monkey}class="grayscale mix-blend-luminosity object-cover opacity-[0.2] w-full h-full" alt="llamitas" loading="lazy"/>
                    </picture>
                </div>
                <div class="pl-5 py-14 pr-5 text-center items-center relative z-10 flex-col justify-between content-center">
                    <h1 class="inset-0 uppercase mb-[0.83em] text-white text-sm md:text-base leading-4 font-bold font-titles">{t('obj.progress.title')}</h1>
                    <div class="box-border text-center items-center content-center">
                        <Image src={Cemento} class="h-32 w-32 inline-block mb-[0.83em]" alt='cemento'/>
                        <div class="py-1 text-left font-titles">
                            <b class="text-white font-semibold leading-5 text-xl md:text-2xl">
                                {t('obj.progress.percent')}
                            </b>
                            <span class="text-white font-normal leading-5 text-lg md:text-xl opacity-70">
                                {t('obj.progress.goal')}
                            </span>
                        </div>
                        <div class="bg-white rounded-xl shadow-sm overflow-hidden p-1 font-titles">
                            <div class="relative h-6 flex items-center justify-center">
                              <div class="absolute top-0 bottom-0 left-0 rounded-lg w-[60%] bg-[#ea5a0c8f]"></div>
                              <div class="relative text-red-900 font-medium text-sm">{t('obj.progress.remaining')}</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</article>
<article class="pb-12 md:pb-8 px-5 md:px-0 md:mr-8 md:ml-8 ml-auto mr-auto lg:ml-auto lg:mr-auto">
    <div class="md:max-w-4xl max-w-lg mx-auto">
        <h2 class="text-[#517b5b] text-2xl md:text-[2rem] font-semibold mb-5 leading-10 capitalize font-titles">{t('obj.chal.title')}</h2>
        <p class="text-gray-500 text-sm md:text-lg font-medium font-body mb-5">{t('obj.chal.desc')}</p>
        <h2 class="text-[#517b5b] text-2xl md:text-[2rem] font-semibold mb-5 mt-12 leading-10 capitalize font-titles">{t('obj.reason.title')}</h2>
        <p class="text-gray-500 text-sm md:text-lg font-medium font-body mb-5">{t('obj.reason.desc')}</p>
        <h2 class="text-[#517b5b] text-2xl md:text-[2rem] font-semibold mb-5 mt-12 leading-10 capitalize font-titles">{t('obj.how.title')}</h2>
        <p class="text-gray-500 text-sm md:text-lg font-medium font-body mb-5">{t('obj.how.desc')}</p>
    </div>
</article>
