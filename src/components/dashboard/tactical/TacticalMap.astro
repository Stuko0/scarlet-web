---
/**
 * TacticalMap — Placeholder container prepared for Mapbox/Leaflet integration.
 * Occupies ~60% of the command center screen. Shows mock fire markers.
 */
---
<div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden flex-1 min-h-[400px] flex flex-col" id="tactical-map-container">
    <div class="px-4 py-3 border-b border-gray-100 flex items-center justify-between bg-white">
        <div class="flex items-center gap-2">
            <div class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></div>
            <h3 class="text-sm font-bold text-gray-800">Mapa Táctico en Vivo</h3>
        </div>
        <div class="flex items-center gap-2">
            <button class="text-xs px-3 py-1.5 rounded-md border border-gray-200 text-gray-600 hover:bg-gray-50 transition-colors font-medium">Satélite</button>
            <button class="text-xs px-3 py-1.5 rounded-md bg-[#ea580c] text-white font-medium hover:bg-[#c24106] transition-colors">Térmica</button>
            <button class="text-xs px-3 py-1.5 rounded-md border border-gray-200 text-gray-600 hover:bg-gray-50 transition-colors font-medium">Calles</button>
        </div>
    </div>

    <!-- Map Placeholder — will integrate Mapbox/Leaflet here -->
    <div class="flex-1 bg-gradient-to-br from-gray-800 via-gray-700 to-gray-900 relative" id="map-placeholder">
        <!-- Grid overlay -->
        <div class="absolute inset-0 opacity-10" style="background-image: repeating-linear-gradient(0deg, transparent, transparent 49px, rgba(255,255,255,.15) 50px), repeating-linear-gradient(90deg, transparent, transparent 49px, rgba(255,255,255,.15) 50px);"></div>

        <!-- Mock fire markers -->
        <div class="absolute top-[20%] left-[30%] group cursor-pointer">
            <div class="relative">
                <span class="animate-ping absolute inline-flex h-6 w-6 rounded-full bg-red-500 opacity-40"></span>
                <span class="relative inline-flex rounded-full h-6 w-6 bg-red-500 border-2 border-white shadow-lg items-center justify-center">
                    <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M12.395 2.553a1 1 0 00-1.45-.385c-.345.23-.614.558-.822.88-.214.33-.403.713-.57 1.116-.334.804-.614 1.768-.84 2.734a31.365 31.365 0 00-.613 3.58 2.64 2.64 0 01-.945-1.067c-.328-.68-.398-1.534-.398-2.654A1 1 0 005.05 6.05 6.981 6.981 0 003 11a7 7 0 1011.95-4.95c-.592-.591-.98-.985-1.348-1.467-.363-.476-.724-1.063-1.207-2.03zM12.12 15.12A3 3 0 017 13s.879.5 2.5.5c0-1 .5-4 1.25-4.5.5 1 .786 1.293 1.371 1.879A2.99 2.99 0 0113 13a2.99 2.99 0 01-.879 2.121z" clip-rule="evenodd"></path></svg>
                </span>
            </div>
            <div class="hidden group-hover:block absolute -top-10 left-1/2 -translate-x-1/2 bg-gray-900 text-white text-xs rounded px-2 py-1 whitespace-nowrap shadow z-10">
                Incendio Zona Norte — P0
            </div>
        </div>

        <div class="absolute top-[55%] left-[60%] group cursor-pointer">
            <div class="relative">
                <span class="animate-ping absolute inline-flex h-5 w-5 rounded-full bg-orange-400 opacity-40"></span>
                <span class="relative inline-flex rounded-full h-5 w-5 bg-orange-400 border-2 border-white shadow-lg items-center justify-center">
                    <svg class="w-2.5 h-2.5 text-white" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M12.395 2.553a1 1 0 00-1.45-.385c-.345.23-.614.558-.822.88-.214.33-.403.713-.57 1.116-.334.804-.614 1.768-.84 2.734a31.365 31.365 0 00-.613 3.58 2.64 2.64 0 01-.945-1.067c-.328-.68-.398-1.534-.398-2.654A1 1 0 005.05 6.05 6.981 6.981 0 003 11a7 7 0 1011.95-4.95c-.592-.591-.98-.985-1.348-1.467-.363-.476-.724-1.063-1.207-2.03zM12.12 15.12A3 3 0 017 13s.879.5 2.5.5c0-1 .5-4 1.25-4.5.5 1 .786 1.293 1.371 1.879A2.99 2.99 0 0113 13a2.99 2.99 0 01-.879 2.121z" clip-rule="evenodd"></path></svg>
                </span>
            </div>
            <div class="hidden group-hover:block absolute -top-10 left-1/2 -translate-x-1/2 bg-gray-900 text-white text-xs rounded px-2 py-1 whitespace-nowrap shadow z-10">
                Incendio Zona Sur — P1
            </div>
        </div>

        <!-- Team marker (blue) -->
        <div class="absolute top-[35%] left-[40%] group cursor-pointer">
            <span class="relative inline-flex rounded-full h-4 w-4 bg-blue-500 border-2 border-white shadow-lg"></span>
            <div class="hidden group-hover:block absolute -top-10 left-1/2 -translate-x-1/2 bg-gray-900 text-white text-xs rounded px-2 py-1 whitespace-nowrap shadow z-10">
                Equipo Alpha — Activo
            </div>
        </div>

        <div class="absolute top-[65%] left-[45%] group cursor-pointer">
            <span class="relative inline-flex rounded-full h-4 w-4 bg-blue-500 border-2 border-white shadow-lg"></span>
            <div class="hidden group-hover:block absolute -top-10 left-1/2 -translate-x-1/2 bg-gray-900 text-white text-xs rounded px-2 py-1 whitespace-nowrap shadow z-10">
                Equipo Bravo — En tránsito
            </div>
        </div>

        <!-- Watermark -->
        <div class="absolute bottom-4 left-4 text-gray-500 text-xs font-mono opacity-60">
            Placeholder — Integrar Mapbox / Leaflet aquí
        </div>

        <!-- Legend -->
        <div class="absolute bottom-4 right-4 bg-gray-900/80 backdrop-blur rounded-lg p-3 text-xs text-gray-300 space-y-1.5">
            <div class="flex items-center gap-2"><span class="w-3 h-3 rounded-full bg-red-500 inline-block"></span> Foco Crítico (P0)</div>
            <div class="flex items-center gap-2"><span class="w-3 h-3 rounded-full bg-orange-400 inline-block"></span> Foco Activo (P1)</div>
            <div class="flex items-center gap-2"><span class="w-3 h-3 rounded-full bg-blue-500 inline-block"></span> Equipo Desplegado</div>
        </div>
    </div>
</div>
