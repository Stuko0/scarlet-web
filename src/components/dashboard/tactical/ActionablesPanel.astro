---
/**
 * ActionablesPanel — Right-side panel showing critical incidents
 * and pending actions requiring immediate decisions.
 */
---
<div class="bg-white rounded-xl shadow-sm border border-gray-100 flex flex-col w-full lg:w-80 flex-shrink-0">
    <div class="px-4 py-3 border-b border-gray-100 flex items-center justify-between">
        <h3 class="text-sm font-bold text-gray-800">Acciones Pendientes</h3>
        <span class="text-xs bg-red-100 text-red-700 px-2 py-0.5 rounded-full font-bold">5</span>
    </div>
    <ul class="flex-1 overflow-y-auto divide-y divide-gray-50 max-h-[500px]">
        <!-- P0 Critical -->
        <li class="px-4 py-3 hover:bg-red-50/40 transition-colors cursor-pointer group">
            <div class="flex items-start gap-3">
                <span class="mt-0.5 w-2 h-2 rounded-full bg-red-500 flex-shrink-0 ring-4 ring-red-100"></span>
                <div class="flex-1 min-w-0">
                    <p class="text-sm font-semibold text-gray-800 truncate group-hover:text-red-700 transition-colors">Incendio Zona Norte sin equipo</p>
                    <p class="text-xs text-gray-500 mt-0.5">Se necesita asignar equipo de respuesta inmediata.</p>
                    <div class="flex items-center gap-2 mt-1.5">
                        <span class="text-[10px] font-bold text-red-600 bg-red-50 px-1.5 py-0.5 rounded">P0</span>
                        <span class="text-[10px] text-gray-400">Hace 3 min</span>
                    </div>
                </div>
                <button class="text-xs text-[#ea580c] font-semibold hover:underline flex-shrink-0 mt-1">Asignar</button>
            </div>
        </li>
        <li class="px-4 py-3 hover:bg-red-50/40 transition-colors cursor-pointer group">
            <div class="flex items-start gap-3">
                <span class="mt-0.5 w-2 h-2 rounded-full bg-red-500 flex-shrink-0 ring-4 ring-red-100"></span>
                <div class="flex-1 min-w-0">
                    <p class="text-sm font-semibold text-gray-800 truncate group-hover:text-red-700 transition-colors">Solicitud de refuerzos — Estación Sur</p>
                    <p class="text-xs text-gray-500 mt-0.5">Equipo Delta solicita 2 unidades adicionales.</p>
                    <div class="flex items-center gap-2 mt-1.5">
                        <span class="text-[10px] font-bold text-red-600 bg-red-50 px-1.5 py-0.5 rounded">P0</span>
                        <span class="text-[10px] text-gray-400">Hace 12 min</span>
                    </div>
                </div>
                <button class="text-xs text-[#ea580c] font-semibold hover:underline flex-shrink-0 mt-1">Aprobar</button>
            </div>
        </li>
        <!-- P1 -->
        <li class="px-4 py-3 hover:bg-orange-50/40 transition-colors cursor-pointer group">
            <div class="flex items-start gap-3">
                <span class="mt-0.5 w-2 h-2 rounded-full bg-orange-400 flex-shrink-0"></span>
                <div class="flex-1 min-w-0">
                    <p class="text-sm font-medium text-gray-800 truncate group-hover:text-orange-700 transition-colors">Vehículo B-07 requiere mantenimiento</p>
                    <p class="text-xs text-gray-500 mt-0.5">Motor con alerta de sobrecalentamiento.</p>
                    <div class="flex items-center gap-2 mt-1.5">
                        <span class="text-[10px] font-bold text-orange-600 bg-orange-50 px-1.5 py-0.5 rounded">P1</span>
                        <span class="text-[10px] text-gray-400">Hace 45 min</span>
                    </div>
                </div>
                <button class="text-xs text-gray-500 font-medium hover:underline flex-shrink-0 mt-1">Revisar</button>
            </div>
        </li>
        <li class="px-4 py-3 hover:bg-orange-50/40 transition-colors cursor-pointer group">
            <div class="flex items-start gap-3">
                <span class="mt-0.5 w-2 h-2 rounded-full bg-orange-400 flex-shrink-0"></span>
                <div class="flex-1 min-w-0">
                    <p class="text-sm font-medium text-gray-800 truncate group-hover:text-orange-700 transition-colors">Reporte pendiente — Incendio controlado #324</p>
                    <p class="text-xs text-gray-500 mt-0.5">Falta informe de cierre del Equipo Alpha.</p>
                    <div class="flex items-center gap-2 mt-1.5">
                        <span class="text-[10px] font-bold text-orange-600 bg-orange-50 px-1.5 py-0.5 rounded">P1</span>
                        <span class="text-[10px] text-gray-400">Hace 2h</span>
                    </div>
                </div>
                <button class="text-xs text-gray-500 font-medium hover:underline flex-shrink-0 mt-1">Revisar</button>
            </div>
        </li>
        <!-- P2 -->
        <li class="px-4 py-3 hover:bg-gray-50 transition-colors cursor-pointer group">
            <div class="flex items-start gap-3">
                <span class="mt-0.5 w-2 h-2 rounded-full bg-gray-400 flex-shrink-0"></span>
                <div class="flex-1 min-w-0">
                    <p class="text-sm font-medium text-gray-700 truncate">Solicitud de transferencia de personal</p>
                    <p class="text-xs text-gray-500 mt-0.5">Miembro A-12 solicita cambio de estación.</p>
                    <div class="flex items-center gap-2 mt-1.5">
                        <span class="text-[10px] font-bold text-gray-500 bg-gray-100 px-1.5 py-0.5 rounded">P2</span>
                        <span class="text-[10px] text-gray-400">Hace 5h</span>
                    </div>
                </div>
                <button class="text-xs text-gray-500 font-medium hover:underline flex-shrink-0 mt-1">Ver</button>
            </div>
        </li>
    </ul>
</div>
