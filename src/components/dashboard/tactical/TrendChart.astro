---
/**
 * TrendChart — Bottom trend area chart showing Activos vs Controlados vs Pendientes.
 * Uses inline SVG chart for zero-dependency rendering.
 */
---
<div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
    <div class="px-4 py-3 border-b border-gray-100 flex items-center justify-between">
        <h3 class="text-sm font-bold text-gray-800">Tendencia Semanal de Incidentes</h3>
        <div class="flex items-center gap-4 text-xs">
            <span class="flex items-center gap-1.5"><span class="w-3 h-0.5 bg-red-500 rounded inline-block"></span> Activos</span>
            <span class="flex items-center gap-1.5"><span class="w-3 h-0.5 bg-emerald-500 rounded inline-block"></span> Controlados</span>
            <span class="flex items-center gap-1.5"><span class="w-3 h-0.5 bg-amber-400 rounded inline-block"></span> Pendientes</span>
        </div>
    </div>

    <div class="p-4 pb-2">
        <div class="flex items-end gap-6 mb-4">
            <div>
                <span class="text-2xl font-bold text-gray-900">12</span>
                <span class="text-xs text-red-500 font-bold ml-1">+4</span>
                <p class="text-xs text-gray-500">Activos</p>
            </div>
            <div>
                <span class="text-2xl font-bold text-gray-900">50</span>
                <span class="text-xs text-emerald-500 font-bold ml-1">+9</span>
                <p class="text-xs text-gray-500">Controlados</p>
            </div>
            <div>
                <span class="text-2xl font-bold text-gray-900">4</span>
                <span class="text-xs text-amber-500 font-bold ml-1">-2</span>
                <p class="text-xs text-gray-500">Pendientes</p>
            </div>
        </div>

        <!-- SVG Chart -->
        <div class="w-full h-32 relative">
            <svg viewBox="0 0 700 120" class="w-full h-full" preserveAspectRatio="none">
                <!-- Grid lines -->
                <line x1="0" y1="30" x2="700" y2="30" stroke="#e5e7eb" stroke-width="0.5" stroke-dasharray="4"/>
                <line x1="0" y1="60" x2="700" y2="60" stroke="#e5e7eb" stroke-width="0.5" stroke-dasharray="4"/>
                <line x1="0" y1="90" x2="700" y2="90" stroke="#e5e7eb" stroke-width="0.5" stroke-dasharray="4"/>

                <!-- Area: Controlados (green) -->
                <path d="M0,80 L100,70 L200,50 L300,40 L400,30 L500,45 L600,35 L700,25 L700,120 L0,120Z" fill="url(#greenGrad)" opacity="0.25"/>
                <polyline points="0,80 100,70 200,50 300,40 400,30 500,45 600,35 700,25" fill="none" stroke="#10b981" stroke-width="2"/>

                <!-- Area: Activos (red) -->
                <path d="M0,95 L100,90 L200,70 L300,55 L400,65 L500,60 L600,75 L700,80 L700,120 L0,120Z" fill="url(#redGrad)" opacity="0.2"/>
                <polyline points="0,95 100,90 200,70 300,55 400,65 500,60 600,75 700,80" fill="none" stroke="#ef4444" stroke-width="2"/>

                <!-- Area: Pendientes (amber) -->
                <path d="M0,105 L100,100 L200,95 L300,100 L400,90 L500,95 L600,100 L700,105 L700,120 L0,120Z" fill="url(#amberGrad)" opacity="0.15"/>
                <polyline points="0,105 100,100 200,95 300,100 400,90 500,95 600,100 700,105" fill="none" stroke="#f59e0b" stroke-width="2" stroke-dasharray="4"/>

                <!-- Dot highlights on Activos -->
                <circle cx="300" cy="55" r="3" fill="#ef4444" />
                <circle cx="500" cy="60" r="3" fill="#ef4444" />

                <!-- Gradients -->
                <defs>
                    <linearGradient id="greenGrad" x1="0" y1="0" x2="0" y2="1">
                        <stop offset="0%" stop-color="#10b981" stop-opacity="0.4"/>
                        <stop offset="100%" stop-color="#10b981" stop-opacity="0"/>
                    </linearGradient>
                    <linearGradient id="redGrad" x1="0" y1="0" x2="0" y2="1">
                        <stop offset="0%" stop-color="#ef4444" stop-opacity="0.4"/>
                        <stop offset="100%" stop-color="#ef4444" stop-opacity="0"/>
                    </linearGradient>
                    <linearGradient id="amberGrad" x1="0" y1="0" x2="0" y2="1">
                        <stop offset="0%" stop-color="#f59e0b" stop-opacity="0.3"/>
                        <stop offset="100%" stop-color="#f59e0b" stop-opacity="0"/>
                    </linearGradient>
                </defs>
            </svg>
        </div>
        <!-- X-axis labels -->
        <div class="flex justify-between text-[10px] text-gray-400 mt-1 px-1">
            <span>Lun</span><span>Mar</span><span>Mié</span><span>Jue</span><span>Vie</span><span>Sáb</span><span>Dom</span>
        </div>
    </div>
</div>
