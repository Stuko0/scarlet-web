---
/** AdminPanel — System health, error logs, tunnel status */
---
<div class="space-y-6">
    <!-- System Health -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div class="bg-white rounded-xl p-5 border border-gray-100 shadow-sm">
            <div class="flex items-center justify-between mb-3">
                <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider">CPU</p>
                <span class="text-xs font-bold text-green-600 bg-green-50 px-2 py-0.5 rounded-full">Normal</span>
            </div>
            <p class="text-3xl font-bold text-gray-900">34%</p>
            <div class="mt-3 w-full bg-gray-100 rounded-full h-2"><div class="bg-green-500 h-2 rounded-full transition-all" style="width: 34%"></div></div>
        </div>
        <div class="bg-white rounded-xl p-5 border border-gray-100 shadow-sm">
            <div class="flex items-center justify-between mb-3">
                <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider">RAM</p>
                <span class="text-xs font-bold text-yellow-600 bg-yellow-50 px-2 py-0.5 rounded-full">Moderado</span>
            </div>
            <p class="text-3xl font-bold text-gray-900">68%</p>
            <div class="mt-3 w-full bg-gray-100 rounded-full h-2"><div class="bg-yellow-500 h-2 rounded-full transition-all" style="width: 68%"></div></div>
        </div>
        <div class="bg-white rounded-xl p-5 border border-gray-100 shadow-sm">
            <div class="flex items-center justify-between mb-3">
                <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Almacenamiento</p>
                <span class="text-xs font-bold text-green-600 bg-green-50 px-2 py-0.5 rounded-full">OK</span>
            </div>
            <p class="text-3xl font-bold text-gray-900">42%</p>
            <div class="mt-3 w-full bg-gray-100 rounded-full h-2"><div class="bg-blue-500 h-2 rounded-full transition-all" style="width: 42%"></div></div>
        </div>
    </div>

    <!-- Error Logs + Tunnels Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <!-- Error Logs -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
            <div class="px-5 py-3 border-b border-gray-100 flex items-center justify-between">
                <h3 class="text-sm font-bold text-gray-800">Logs de Errores Recientes</h3>
                <span class="text-xs text-gray-400">Últimas 24h</span>
            </div>
            <div class="divide-y divide-gray-50 max-h-72 overflow-y-auto">
                {[
                    { time: '00:14:32', level: 'ERROR', msg: 'Connection timeout PostgreSQL (pool_id: 7)', color: 'red' },
                    { time: '23:58:01', level: 'WARN', msg: 'Rate limit hit NATS subject telemetry.gps', color: 'yellow' },
                    { time: '23:45:11', level: 'ERROR', msg: 'JWT token validation failed (user_id: 491)', color: 'red' },
                    { time: '22:30:07', level: 'INFO', msg: 'Backup completado exitosamente (152 GB)', color: 'blue' },
                    { time: '21:15:44', level: 'WARN', msg: 'Memory usage above 80% on worker-3', color: 'yellow' },
                ].map(log => (
                    <div class="px-5 py-2.5 flex items-start gap-3 text-xs font-mono hover:bg-gray-50 transition-colors">
                        <span class="text-gray-400 flex-shrink-0">{log.time}</span>
                        <span class={`font-bold flex-shrink-0 ${log.color === 'red' ? 'text-red-600' : log.color === 'yellow' ? 'text-yellow-600' : 'text-blue-600'}`}>{log.level}</span>
                        <span class="text-gray-600 truncate">{log.msg}</span>
                    </div>
                ))}
            </div>
        </div>

        <!-- Tunnel Status -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
            <div class="px-5 py-3 border-b border-gray-100">
                <h3 class="text-sm font-bold text-gray-800">Estado de Conexiones / Túneles</h3>
            </div>
            <div class="p-5 space-y-4">
                {[
                    { name: 'API Gateway (Envoy)', status: 'online', latency: '12ms' },
                    { name: 'Base de Datos Principal', status: 'online', latency: '3ms' },
                    { name: 'NATS Message Broker', status: 'online', latency: '1ms' },
                    { name: 'Redis Cache', status: 'online', latency: '<1ms' },
                    { name: 'Worker Telemetría', status: 'degraded', latency: '250ms' },
                ].map(t => (
                    <div class="flex items-center justify-between">
                        <div class="flex items-center gap-3">
                            <span class={`w-2.5 h-2.5 rounded-full flex-shrink-0 ${t.status === 'online' ? 'bg-green-500' : t.status === 'degraded' ? 'bg-yellow-500 animate-pulse' : 'bg-red-500'}`}></span>
                            <span class="text-sm text-gray-700 font-medium">{t.name}</span>
                        </div>
                        <div class="flex items-center gap-3">
                            <span class="text-xs text-gray-400 font-mono">{t.latency}</span>
                            <span class={`text-xs font-bold px-2 py-0.5 rounded-full ${t.status === 'online' ? 'bg-green-50 text-green-700' : 'bg-yellow-50 text-yellow-700'}`}>{t.status === 'online' ? 'Online' : 'Degradado'}</span>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </div>
</div>
