---
/** NotificationFullPage — Full notification history with filters. Fully responsive. */
---
<div class="space-y-4 md:space-y-6">
    <!-- Filters -->
    <div class="flex flex-col gap-3">
        <div class="flex flex-col sm:flex-row gap-3 items-stretch sm:items-center justify-between">
            <div class="relative w-full sm:w-64">
                <svg class="w-4 h-4 text-gray-400 absolute left-3 top-2.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                <input type="text" placeholder="Buscar notificación..." class="pl-9 pr-4 py-2 border border-gray-200 rounded-lg text-sm focus:border-[#ea580c] focus:ring focus:ring-[#ea580c]/20 w-full" />
            </div>
            <button class="text-xs text-[#ea580c] font-semibold hover:underline self-end sm:self-auto">Marcar todas como leídas</button>
        </div>
        <div class="flex flex-wrap gap-2">
            <select class="text-xs border border-gray-200 rounded-lg px-3 py-2 bg-white text-gray-600 flex-1 min-w-[120px]">
                <option value="">Todas las Severidades</option>
                <option value="critical">Crítica</option>
                <option value="warning">Advertencia</option>
                <option value="info">Información</option>
            </select>
            <select class="text-xs border border-gray-200 rounded-lg px-3 py-2 bg-white text-gray-600 flex-1 min-w-[120px]">
                <option value="">Últimos 7 días</option>
                <option value="today">Hoy</option>
                <option value="30">Últimos 30 días</option>
                <option value="all">Todo</option>
            </select>
        </div>
    </div>

    <!-- Notification List -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
        <div class="divide-y divide-gray-50">
            {[
                { sev: 'critical', title: 'Incendio Zona Norte sin equipo asignado', desc: 'Se requiere asignar equipo de respuesta inmediata. Incendio activo con 0 personal desplegado.', time: 'Hace 3 min', read: false },
                { sev: 'critical', title: 'Solicitud de refuerzos — Estación Sur', desc: 'Equipo Delta solicita 2 unidades adicionales por expansión del perímetro afectado.', time: 'Hace 12 min', read: false },
                { sev: 'warning', title: 'Vehículo B-07 alerta de sobrecalentamiento', desc: 'Motor con temperatura superior al umbral operativo. Requiere inspección.', time: 'Hace 45 min', read: false },
                { sev: 'info', title: 'Informe semanal generado', desc: 'El reporte de actividad de la semana 12 está disponible para descarga.', time: 'Hace 2 horas', read: true },
                { sev: 'warning', title: 'Reporte pendiente — Incendio INC-324', desc: 'Equipo Alpha no ha enviado informe de cierre. Plazo vencido.', time: 'Hace 3 horas', read: true },
                { sev: 'info', title: 'Nuevo voluntario registrado', desc: 'Vol. Martínez ha completado el proceso de registro en Estación Central.', time: 'Hace 5 horas', read: true },
                { sev: 'info', title: 'Backup completado exitosamente', desc: 'Respaldo automático del sistema completado (152 GB).', time: 'Hace 8 horas', read: true },
                { sev: 'critical', title: 'Foco de calor detectado — Sector Industrial', desc: 'Sensor satelital detectó anomalía térmica en coordenadas -33.412, -70.601.', time: 'Ayer 18:30', read: true },
            ].map(n => (
                <div class={`px-3 py-3 sm:px-5 sm:py-4 flex items-start gap-3 sm:gap-4 hover:bg-gray-50 transition-colors cursor-pointer ${!n.read ? 'bg-orange-50/30' : ''}`}>
                    <span class={`mt-1 w-2.5 h-2.5 rounded-full flex-shrink-0 ${n.sev === 'critical' ? 'bg-red-500' : n.sev === 'warning' ? 'bg-yellow-500' : 'bg-blue-400'}`}></span>
                    <div class="flex-1 min-w-0">
                        <div class="flex items-start sm:items-center gap-2 flex-col sm:flex-row">
                            <p class={`text-sm font-semibold text-gray-800 ${!n.read ? 'font-bold' : ''}`}>{n.title}</p>
                            <div class="flex items-center gap-2">
                                {!n.read && <span class="w-2 h-2 bg-[#ea580c] rounded-full flex-shrink-0"></span>}
                                <span class="text-[10px] text-gray-400 flex-shrink-0 whitespace-nowrap sm:hidden">{n.time}</span>
                            </div>
                        </div>
                        <p class="text-xs text-gray-500 mt-1">{n.desc}</p>
                    </div>
                    <span class="text-[10px] text-gray-400 flex-shrink-0 whitespace-nowrap mt-1 hidden sm:block">{n.time}</span>
                </div>
            ))}
        </div>
    </div>
</div>
