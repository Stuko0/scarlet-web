---
interface Props {
    viewTitle: string;
}
const { viewTitle } = Astro.props;
---

<div class="flex-1 flex flex-col gap-6" id="form-manager">
    <div class="grid grid-cols-1 xl:grid-cols-4 gap-6">
        <div class="xl:col-span-1 flex flex-col gap-4">
            <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
                <div class="bg-gray-50 p-4 border-b border-gray-100 font-bold text-gray-700 text-sm tracking-wide">Formularios Activos</div>
                <div class="divide-y divide-gray-100" id="form-list"></div>
            </div>
        </div>
        <div class="xl:col-span-3 bg-white rounded-xl shadow-sm border border-gray-100 p-6 flex flex-col">
            <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center border-b pb-4 mb-6 gap-4">
                <div>
                    <h2 class="text-xl font-bold font-titles flex items-center" id="form-title-display"></h2>
                    <p class="text-sm text-gray-500 mt-1" id="form-url-display"></p>
                </div>
                <div class="flex gap-2">
                    <button class="text-gray-600 hover:text-gray-900 bg-gray-100 hover:bg-gray-200 px-3 py-1.5 rounded text-sm font-medium">Respuestas</button>
                    <button class="text-white bg-green-600 hover:bg-green-700 px-3 py-1.5 rounded text-sm font-medium flex items-center">
                        <svg class="w-4 h-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg> Compartir
                    </button>
                </div>
            </div>
            <div class="flex-1 bg-gray-50 rounded-lg border-2 border-dashed border-gray-200 p-4 sm:p-6 space-y-4" id="form-fields-canvas"></div>
            <div class="flex justify-center mt-6">
                <button id="add-form-field" class="bg-white shadow border border-gray-200 text-gray-700 hover:text-[#ea580c] hover:border-[#ea580c] rounded-full w-12 h-12 flex items-center justify-center transition-all focus:outline-none">
                    <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                </button>
            </div>
        </div>
    </div>
</div>

<script is:inline>
(function(){
    let forms=[{id:'f1',name:'Formulario de Contacto Principal',url:'contact-main',responses:283,fields:[
        {id:'q1',question:'Nombre Completo',type:'text',options:[]},
        {id:'q2',question:'Motivo del Contacto',type:'multiple',options:['Soporte Técnico','Información','Otro']}
    ]},{id:'f2',name:'Registro de Equipos',url:'team-register',responses:12,fields:[
        {id:'q1',question:'Nombre del Equipo',type:'text',options:[]}
    ]},{id:'f3',name:'Encuesta a Bomberos',url:'fire-survey',responses:64,fields:[
        {id:'q1',question:'Años de experiencia',type:'text',options:[]}
    ]}];
    let activeFormId='f1',fc=10;

    function renderList(){
        const el=document.getElementById('form-list');if(!el)return;
        el.innerHTML=forms.map(f=>`<div class="p-4 cursor-pointer border-l-4 transition-colors form-list-item ${f.id===activeFormId?'bg-orange-50/50 border-[#ea580c]':'hover:bg-gray-50 border-transparent'}" data-fid="${f.id}">
            <h4 class="${f.id===activeFormId?'font-semibold tracking-wide text-sm text-gray-900':'font-medium text-sm text-gray-700'}">${f.name}</h4>
            <p class="text-xs text-gray-500 mt-1">${f.responses} Respuestas</p></div>`).join('');
        el.querySelectorAll('.form-list-item').forEach(i=>i.addEventListener('click',()=>{activeFormId=i.dataset.fid;renderList();renderBuilder();}));
    }

    function renderBuilder(){
        const form=forms.find(f=>f.id===activeFormId);if(!form)return;
        const td=document.getElementById('form-title-display'),ud=document.getElementById('form-url-display'),cv=document.getElementById('form-fields-canvas');
        if(td)td.textContent=form.name;if(ud)ud.textContent='https://scarlet.com/form/'+form.url;
        if(!cv)return;
        cv.innerHTML=form.fields.map((field,idx)=>{
            let fc='';
            if(field.type==='text')fc=`<input type="text" disabled placeholder="Texto de respuesta corta" class="w-full sm:w-1/2 border-b border-dashed border-gray-400 bg-transparent py-2 mt-2 text-sm"/>`;
            else if(field.type==='paragraph')fc=`<textarea disabled placeholder="Texto largo..." class="w-full border-b border-dashed border-gray-400 bg-transparent py-2 mt-2 text-sm resize-none" rows="2"></textarea>`;
            else if(field.type==='multiple')fc=`<div class="mt-4 space-y-2">${field.options.map((o,oi)=>`<div class="flex items-center gap-2"><div class="w-4 h-4 rounded-full border border-gray-400 shrink-0"></div><input type="text" value="${o}" class="text-sm border-b border-transparent hover:border-gray-300 w-full sm:w-1/3 outline-none min-w-[150px] fo-input" data-fid="${field.id}" data-oi="${oi}"/><span class="text-red-500 font-bold ml-auto cursor-pointer text-sm ro-btn" data-fid="${field.id}" data-oi="${oi}">✕</span></div>`).join('')}<button class="text-[#ea580c] text-sm font-medium hover:underline ao-btn" data-fid="${field.id}">+ Agregar opción</button></div>`;
            return `<div class="bg-white p-4 lg:p-6 rounded-lg shadow-[0_4px_12px_rgba(0,0,0,0.05)] border border-gray-100 relative group cursor-pointer hover:border-[#ea580c] transition-colors">
                <div class="absolute -top-3 -right-3 bg-red-500 text-white rounded-full w-6 h-6 flex items-center justify-center opacity-0 group-hover:opacity-100 cursor-pointer shadow-md transition-opacity rf-btn" data-fid="${field.id}">✕</div>
                <div class="flex flex-col sm:flex-row sm:justify-between sm:items-start mb-2 gap-3">
                    <input type="text" value="Pregunta ${idx+1}: ${field.question}" class="font-bold text-gray-800 text-lg border-b border-transparent hover:border-gray-300 focus:border-[#ea580c] focus:outline-none bg-transparent w-full sm:w-2/3 transition-colors fq-input" data-fid="${field.id}"/>
                    <select class="border border-gray-300 rounded p-1.5 text-sm w-full sm:w-40 text-gray-600 focus:outline-[#ea580c] bg-white ft-sel" data-fid="${field.id}">
                        <option value="text" ${field.type==='text'?'selected':''}>Texto Corto</option>
                        <option value="paragraph" ${field.type==='paragraph'?'selected':''}>Párrafo</option>
                        <option value="multiple" ${field.type==='multiple'?'selected':''}>Varias opciones</option>
                    </select></div>${fc}</div>`;
        }).join('');
        cv.querySelectorAll('.rf-btn').forEach(b=>b.addEventListener('click',()=>{form.fields=form.fields.filter(f=>f.id!==b.dataset.fid);renderBuilder();}));
        cv.querySelectorAll('.fq-input').forEach(i=>i.addEventListener('change',()=>{const f=form.fields.find(x=>x.id===i.dataset.fid);if(f)f.question=i.value.replace(/^Pregunta \d+:\s*/,'');}));
        cv.querySelectorAll('.ft-sel').forEach(s=>s.addEventListener('change',()=>{const f=form.fields.find(x=>x.id===s.dataset.fid);if(f){f.type=s.value;if(s.value==='multiple'&&f.options.length===0)f.options=['Opción 1'];renderBuilder();}}));
        cv.querySelectorAll('.fo-input').forEach(i=>i.addEventListener('change',()=>{const f=form.fields.find(x=>x.id===i.dataset.fid);if(f)f.options[parseInt(i.dataset.oi)]=i.value;}));
        cv.querySelectorAll('.ro-btn').forEach(b=>b.addEventListener('click',()=>{const f=form.fields.find(x=>x.id===b.dataset.fid);if(f){f.options.splice(parseInt(b.dataset.oi),1);renderBuilder();}}));
        cv.querySelectorAll('.ao-btn').forEach(b=>b.addEventListener('click',()=>{const f=form.fields.find(x=>x.id===b.dataset.fid);if(f){f.options.push('Nueva opción');renderBuilder();}}));
    }

    document.getElementById('add-form-field')?.addEventListener('click',()=>{const form=forms.find(f=>f.id===activeFormId);if(form){fc++;form.fields.push({id:'q'+fc,question:'Nueva Pregunta',type:'text',options:[]});renderBuilder();}});

    window.addNewForm=function(name,url){
        const nf={id:'f'+Date.now(),name,url,responses:0,fields:[{id:'q1',question:'Primera Pregunta',type:'text',options:[]}]};
        forms.push(nf);activeFormId=nf.id;renderList();renderBuilder();
    };
    renderList();renderBuilder();
})();
</script>
