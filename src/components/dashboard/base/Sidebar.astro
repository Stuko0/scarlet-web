---
import { getLangFromUrl } from '../../../i18n/utils';

const currentPath = Astro.url.pathname;
const lang = getLangFromUrl(Astro.url);
const b = `/${lang}`;

const isActive = (path: string) => currentPath.endsWith(path);
const isGroupActive = (paths: string[]) => paths.some(p => currentPath.endsWith(p));

const svgFillActive = (path: string) => isActive(path) ? "#ea580c" : "#000000";
const svgStrokeActive = (path: string) => isActive(path) ? "#ea580c" : "currentColor";
---
<div class="md:hidden z-50 fixed top-3 left-3">
    <button id="hamburger-open" class="p-2 rounded-lg bg-white shadow-md border border-gray-200 hover:bg-gray-50 transition-colors">
        <svg class="w-5 h-5 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
    </button>
</div>
<div class="hidden toggle md:flex flex-col" id="menu">
    <div class="fixed left-0 top-0 w-56 md:w-64 h-full bg-[#f1efec] p-4 border border-r-[#d1d5db] z-50 flex flex-col">
        <div class="flex items-center pb-4 border-b border-b-gray-800">
            <a href={b} class="flex items-center">
                <svg class="md:w-10 md:max-w-16 w-7 max-w-7" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" stroke="#fb5335"><g id="SVGRepo_bgCarrier" stroke-width="0"></g><g id="SVGRepo_tracerCarrier" stroke-linecap="round" stroke-linejoin="round"></g><g id="SVGRepo_iconCarrier"><path d="M5.926 20.574a7.26 7.26 0 0 0 3.039 1.511c.107.035.179-.105.107-.175-2.395-2.285-1.079-4.758-.107-5.873.693-.796 1.68-2.107 1.608-3.865 0-.176.18-.317.322-.211 1.359.703 2.288 2.25 2.538 3.515.394-.386.537-.984.537-1.511 0-.176.214-.317.393-.176 1.287 1.16 3.503 5.097-.072 8.19-.071.071 0 .212.072.177a8.761 8.761 0 0 0 3.003-1.442c5.827-4.5 2.037-12.48-.43-15.116-.321-.317-.893-.106-.893.351-.036.95-.322 2.004-1.072 2.707-.572-2.39-2.478-5.105-5.195-6.441-.357-.176-.786.105-.75.492.07 3.27-2.063 5.352-3.922 8.059-1.645 2.425-2.717 6.89.822 9.808z" fill="#fbae00"></path></g></svg>
                <span class="text-lg font-titles font-bold text-black ml-3">!Scarlet</span>    
            </a>
            <div class="md:hidden ml-auto">
                <button id="hamburger-close" class="p-1.5 rounded-lg hover:bg-gray-200 transition-colors">
                    <svg class="w-5 h-5 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>
        </div>
        
        <ul class="mt-4 flex-1 overflow-y-auto">
            <h2 class="font-titles font-bold mb-2 text-sm text-gray-500 uppercase tracking-wider">Paneles</h2>
            <li class={`mb-1 group ${isActive('dashboard/Dashboard') ? 'active' : ''}`}>
                <a href={`${b}/dashboard/Dashboard`} class="flex items-center py-2 px-4 text-black hover:bg-white hover:text-black rounded-md group-[.active]:bg-gray-50 group-[.active]:text-[#ea580c] group-[.active]:font-semibold">
                    <svg class="md:w-5 w-4 mr-3" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg" fill="#000000"><g><path fill="#b2b2b2" d="M21.49,4.51A12,12,0,1,0,13,25a1,1,0,0,0,1-1V13.41l7.49-7.49a1,1,0,0,0,.29-.7A1,1,0,0,0,21.49,4.51Z"></path><path fill={svgFillActive('dashboard/Dashboard')} d="M27.49,6.51a1,1,0,0,0-1.41,0l-7.79,7.78a1,1,0,0,0-.29.79,1,1,0,0,0,.42.73l9,6.4a1,1,0,0,0,.58.19l.16,0a1,1,0,0,0,.65-.4A12,12,0,0,0,27.49,6.51Z"></path></g></svg>
                    <span class="font-body text-sm">Resumen Analítico</span>
                </a> 
            </li>
            <li class={`mb-1 group ${isActive('dashboard/panel-admin') ? 'active' : ''}`}>
                <a href={`${b}/dashboard/panel-admin`} class="flex items-center py-2 px-4 text-black hover:bg-white hover:text-black rounded-md group-[.active]:bg-gray-50 group-[.active]:text-[#ea580c] group-[.active]:font-semibold">
                    <svg class="md:w-5 w-4 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
                    <span class="font-body text-sm">Panel de Administrador</span>
                </a> 
            </li>
            <li class={`mb-1 group ${isActive('dashboard/panel-orquestador') ? 'active' : ''}`}>
                <a href={`${b}/dashboard/panel-orquestador`} class="flex items-center py-2 px-4 text-black hover:bg-white hover:text-black rounded-md group-[.active]:bg-gray-50 group-[.active]:text-[#ea580c] group-[.active]:font-semibold">
                    <svg class="md:w-5 w-4 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"></path></svg>
                    <span class="font-body text-sm">Entidad Orquestadora</span>
                </a> 
            </li>
            <li class={`mb-1 group ${isActive('dashboard/panel-entidad') ? 'active' : ''}`}>
                <a href={`${b}/dashboard/panel-entidad`} class="flex items-center py-2 px-4 text-black hover:bg-white hover:text-black rounded-md group-[.active]:bg-gray-50 group-[.active]:text-[#ea580c] group-[.active]:font-semibold">
                    <svg class="md:w-5 w-4 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
                    <span class="font-body text-sm">Panel de Entidad</span>
                </a> 
            </li>
            <li class={`mb-1 group ${isActive('dashboard/panel-estacion') ? 'active' : ''}`}>
                <a href={`${b}/dashboard/panel-estacion`} class="flex items-center py-2 px-4 text-black hover:bg-white hover:text-black rounded-md group-[.active]:bg-gray-50 group-[.active]:text-[#ea580c] group-[.active]:font-semibold">
                    <svg class="md:w-5 w-4 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
                    <span class="font-body text-sm">Panel de Estación</span>
                </a> 
            </li>
            <li class={`mb-4 pb-4 border-b border-b-gray-800 group ${isActive('dashboard/panel-equipo') ? 'active' : ''}`}>
                <a href={`${b}/dashboard/panel-equipo`} class="flex items-center py-2 px-4 text-black hover:bg-white hover:text-black rounded-md group-[.active]:bg-gray-50 group-[.active]:text-[#ea580c] group-[.active]:font-semibold">
                    <svg class="md:w-5 w-4 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
                    <span class="font-body text-sm">Panel de Equipo</span>
                </a> 
            </li>

            <h2 class="font-titles font-bold mb-2 text-sm text-gray-500 uppercase tracking-wider">Elementos Gráficos</h2>
            <li class={`mb-1 group ${isGroupActive(['mantenimiento', 'error-404', 'error-500']) ? 'selected' : ''}`}>
                <a href="#" class="flex items-center py-2 px-4 text-black hover:bg-white hover:text-black rounded-md sidebar-dropdown-toggle group-[.selected]:bg-gray-100">
                    <svg class="md:w-5 w-4 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z"></path></svg>
                     <span class="font-body text-sm text-gray-800">Paginas</span>
                     <svg class="ml-auto group-[.selected]:rotate-90 text-gray-500"  xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24"><path fill="currentColor" d="m12.404 8.303l3.431 3.327c.22.213.22.527 0 .74l-6.63 6.43C8.79 19.201 8 18.958 8 18.43v-5.723z"/><path fill="currentColor" d="M8 11.293V5.57c0-.528.79-.771 1.205-.37l2.481 2.406z" opacity="0.5"/></svg>
                 </a>
                 <ul class="pl-7 mr-2 hidden group-[.selected]:block mt-2">
                     <li class="mb-2">
                         <a href={`${b}/dashboard/mantenimiento`} class={`flex text-gray-600 text-sm hover:text-[#ea580c] transition-colors ${isActive('mantenimiento') ? 'text-[#ea580c] font-semibold' : ''}`}>Mantenimiento</a>
                     </li>
                     <li class="mb-2">
                         <a href={`${b}/dashboard/error-404`} class={`flex text-gray-600 text-sm hover:text-[#ea580c] transition-colors ${isActive('error-404') ? 'text-[#ea580c] font-semibold' : ''}`}>404 no encontrado</a>
                     </li>
                     <li class="mb-2">
                        <a href={`${b}/dashboard/error-500`} class={`flex text-gray-600 text-sm hover:text-[#ea580c] transition-colors ${isActive('error-500') ? 'text-[#ea580c] font-semibold' : ''}`}>500 error</a>
                    </li>
                </ul>
            </li>
            <li class={`mb-1 group ${isActive('dashboard/formularios') ? 'active' : ''}`}>
                <a href={`${b}/dashboard/formularios`} class="flex items-center py-2 px-4 text-black hover:bg-white hover:text-black rounded-md group-[.active]:bg-gray-50 group-[.active]:text-[#ea580c] group-[.active]:font-semibold">
                    <svg class="md:w-5 w-4 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"></path></svg>
                    <span class="font-body text-sm">Formularios</span>
                </a>
            </li>
            <li class={`mb-4 pb-4 border-b border-b-gray-800 group ${isActive('dashboard/archivos') ? 'active' : ''}`}>
                <a href={`${b}/dashboard/archivos`} class="flex items-center py-2 px-4 text-black hover:bg-white hover:text-black rounded-md group-[.active]:bg-gray-50 group-[.active]:text-[#ea580c] group-[.active]:font-semibold">
                    <svg class="md:w-5 w-4 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"></path></svg>
                    <span class="font-body text-sm">Gestor de Archivos</span>
                </a> 
            </li>

            <h2 class="font-titles font-bold mb-2 text-sm text-gray-500 uppercase tracking-wider">Funciones Web</h2>
            <li class={`mb-1 group ${isActive('dashboard/usuarios') ? 'active' : ''}`}>
                <a href={`${b}/dashboard/usuarios`} class="flex items-center py-2 px-4 text-black hover:bg-white hover:text-black rounded-md group-[.active]:bg-gray-50 group-[.active]:text-[#ea580c] group-[.active]:font-semibold">
                    <svg class="md:w-5 w-4 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
                    <span class="font-body text-sm">Usuarios y Accesos</span>
                </a> 
            </li>
            <li class={`mb-1 group ${isActive('dashboard/equipos') ? 'active' : ''}`}>
                <a href={`${b}/dashboard/equipos`} class="flex items-center py-2 px-4 text-black hover:bg-white hover:text-black rounded-md group-[.active]:bg-gray-50 group-[.active]:text-[#ea580c] group-[.active]:font-semibold">
                    <svg class="md:w-5 w-4 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
                    <span class="font-body text-sm">Gestión Equipos</span>
                </a> 
            </li>
            <li class={`mb-1 group ${isActive('dashboard/entidades') ? 'active' : ''}`}>
                <a href={`${b}/dashboard/entidades`} class="flex items-center py-2 px-4 text-black hover:bg-white hover:text-black rounded-md group-[.active]:bg-gray-50 group-[.active]:text-[#ea580c] group-[.active]:font-semibold">
                    <svg class="md:w-5 w-4 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
                    <span class="font-body text-sm">Gestión Entidades</span>
                </a> 
            </li>
            <li class={`group ${isActive('dashboard/tareas') ? 'active' : ''}`}>
                <a href={`${b}/dashboard/tareas`} class="flex items-center py-2 px-4 text-black hover:bg-white hover:text-black rounded-md group-[.active]:bg-gray-50 group-[.active]:text-[#ea580c] group-[.active]:font-semibold">
                    <svg class="md:w-5 w-4 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"></path></svg>
                    <span class="font-body text-sm">Tareas Asignadas</span>
                </a> 
            </li>
        </ul>

        <!-- Bottom tools: Notifications and Settings -->
        <div class="mt-auto pt-4 border-t border-gray-800 flex flex-col gap-1 flex-shrink-0">
            
            <!-- MOBILE: Inline accordion (no popover) -->
            <div class="md:hidden">
                <button id="notif-mobile-toggle" class="w-full flex items-center py-2 px-4 text-gray-700 hover:bg-white rounded-md transition-colors">
                    <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"></path></svg>
                    <span class="font-body text-sm">Notificaciones</span>
                    <span class="ml-auto bg-[#ea580c] text-white text-xs px-2 py-0.5 rounded-full font-bold">3</span>
                    <svg class="w-4 h-4 ml-2 text-gray-400 transition-transform notif-chevron" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                </button>
                <div id="notif-mobile-panel" class="hidden mt-1 mx-2 rounded-lg border border-gray-200 bg-white overflow-hidden shadow-sm">
                    <div class="bg-gray-50 px-4 py-2.5 border-b border-gray-100 flex justify-between items-center">
                        <span class="font-semibold text-gray-700 text-xs">Recientes</span>
                        <a href="#" class="text-[10px] text-[#ea580c] hover:underline font-medium">Marcar leídas</a>
                    </div>
                    <ul class="max-h-48 overflow-y-auto">
                        <li>
                            <a href="#" class="py-2.5 px-3 flex items-start border-b border-gray-50 hover:bg-gray-50 transition-colors">
                                <div class="w-7 h-7 rounded-full bg-blue-100 flex items-center justify-center flex-shrink-0 mt-0.5">
                                    <svg class="w-3.5 h-3.5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                                </div>
                                <div class="ml-2.5">
                                    <p class="text-[12px] text-gray-700 font-medium leading-tight">Nueva tarea asignada</p>
                                    <p class="text-[10px] text-gray-400 mt-0.5">Hace 5 min</p>
                                </div>
                            </a>
                        </li>
                        <li>
                            <a href="#" class="py-2.5 px-3 flex items-start hover:bg-gray-50 transition-colors">
                                <div class="w-7 h-7 rounded-full bg-red-100 flex items-center justify-center flex-shrink-0 mt-0.5">
                                    <svg class="w-3.5 h-3.5 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                                </div>
                                <div class="ml-2.5">
                                    <p class="text-[12px] text-gray-700 font-medium leading-tight">Nuevo Incendio Registrado</p>
                                    <p class="text-[10px] text-gray-400 mt-0.5">Hace 2 horas</p>
                                </div>
                            </a>
                        </li>
                    </ul>
                    <div class="border-t border-gray-100 px-3 py-2 bg-gray-50">
                        <a href={`${b}/dashboard/notificaciones`} class="text-[11px] text-[#ea580c] hover:underline font-semibold flex items-center justify-center gap-1">
                            Ver todas
                            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                        </a>
                    </div>
                </div>
            </div>

            <!-- DESKTOP: Popper.js popover (original behavior) -->
            <div class="dropdown group relative hidden md:block" style="overflow: visible;">
                <button class="w-full flex items-center py-2 px-4 text-gray-700 hover:bg-white rounded-md dropdown-toggle transition-colors group-hover:text-[#ea580c]">
                    <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"></path></svg>
                    <span class="font-body text-sm">Notificaciones</span>
                    <span class="ml-auto bg-[#ea580c] text-white text-xs px-2 py-0.5 rounded-full font-bold">3</span>
                </button>

                <div class="dropdown-menu absolute bottom-full left-0 mb-2 shadow-lg shadow-black/10 z-50 hidden w-80 bg-white rounded-lg border border-gray-200 overflow-hidden transition-opacity origin-bottom-left">
                    <div class="bg-gray-50 px-4 py-3 border-b border-gray-100 flex justify-between items-center">
                        <span class="font-semibold text-gray-700 text-sm">Tus Notificaciones</span>
                        <a href="#" class="text-xs text-[#ea580c] hover:underline font-medium">Marcar leídas</a>
                    </div>
                    <ul class="max-h-64 overflow-y-auto">
                        <li>
                            <a href="#" class="py-3 px-4 flex items-start border-b border-gray-50 hover:bg-gray-50 transition-colors group/notif">
                                <div class="w-8 h-8 rounded-full bg-blue-100 flex items-center justify-center flex-shrink-0 mt-0.5">
                                    <svg class="w-4 h-4 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
